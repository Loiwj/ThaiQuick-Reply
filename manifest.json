{
  "manifest_version": 3,
  "name": "ThaiQuick Reply",
  "version": "2.2.0",
  "description": "Hỗ trợ creator Việt đọc và trả lời bình luận tiếng Thái tự nhiên, sát nghĩa nhất.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "clipboardWrite", "nativeMessaging"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.mymemory.translated.net/*",
    "https://api.kimi.com/*",
    "https://api.cloudflare.com/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ThaiQuick Reply",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://studio.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
