{
  "manifest_version": 3,
  "name": "Thai Comment Manager",
  "version": "3.0.0",
  "description": "Xuất bình luận tiếng Thái thành JSON, nhờ AI dịch & tạo reply, rồi import lại để phản hồi nhanh trên YouTube Studio.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "clipboardWrite"],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Thai Comment Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://studio.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
